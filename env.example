# PostgreSQL Database Configuration
# Copy this file to .env and fill in your database details

# Database connection settings (Vite requires VITE_ prefix)
VITE_DB_HOST=localhost
VITE_DB_PORT=5432
VITE_DB_NAME=localeyes
VITE_DB_USER=postgres
VITE_DB_PASSWORD=your_password_here

# If any of these are not set, the app will use localStorage instead
